            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "LLM Chain - Parse Exam Questions": {
      "main": [
        [
          {
            "node": "Parse Agent JSON Output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Agent JSON Output": {
      "main": [
        [
          {
            "node": "Upsert to Pinecone",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "LLM Chain - Parse Exam Questions",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI Embeddings": {
      "ai_embedding": [
        [
          {
            "node": "Upsert to Pinecone",
            "type": "ai_embedding",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "saveExecutionProgress": true,
    "errorWorkflow": ""
  },
  "staticData": null,
